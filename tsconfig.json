{
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "baseUrl": "./src",
    "paths": {
      "*": [
        "./types/*",
        "node_modules/@types/*"
      ]
    },
    "lib": [
      "ESNext"
    ]
  },
  "include": [
    "./src/**/*.js",
    "./types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}